      "properties": {
        "offset": {
          "x": 0,
          "y": 3150
        },
        "service": "{{trigger.message.InstanceSid}}",
        "channel": "{{trigger.message.ChannelSid}}",
        "from": "{{flow.channel.address}}",
        "message_type": "custom",
        "body": "Validado ✅ Encontrei seu pedido recente:\n\n📦 *Pedido #{{widgets.http_get_order.parsed.orderId}}*\n🛍️ {{widgets.http_get_order.parsed.itemSummary}}\n📊 Status: {{widgets.http_get_order.parsed.statusLabel}}\n🕐 Previsão: {{widgets.http_get_order.parsed.eta}}\n\nQual é o problema com esse pedido?\n\n*1* — Atraso na entrega\n*2* — Item faltando ou incorreto\n*3* — Questão de cobrança\n*4* — Outro / Falar com atendente",
        "timeout": "300"
      }
    },
    {
      "name": "split_issue",
      "type": "split-based-on",
      "transitions": [
        {
          "next": "msg_esc_direct",
          "event": "noMatch"
        },
        {
          "next": "http_resolve_delay",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "atraso",
              "arguments": [
                "{{widgets.order_issue_q.inbound.Body}}"
              ],
              "type": "matches_any_of",
              "value": "1,atraso,Atraso,atrasou,demora,Demora,demorou"
            }
          ]
        },
        {
          "next": "http_resolve_missing",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "item faltando",
              "arguments": [
                "{{widgets.order_issue_q.inbound.Body}}"
              ],
              "type": "matches_any_of",
              "value": "2,faltando,Faltando,item,Item,errado,Errado,incompleto"
            }
          ]
        },
        {
          "next": "msg_esc_billing",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "cobranca",
              "arguments": [
                "{{widgets.order_issue_q.inbound.Body}}"
              ],
              "type": "matches_any_of",
              "value": "3,cobrança,Cobrança,cobranca,Cobranca,financeiro,Financeiro,pagamento"
            }
          ]
        },
        {
          "next": "msg_esc_direct",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "outro ou atendente",
              "arguments": [
                "{{widgets.order_issue_q.inbound.Body}}"
              ],
              "type": "matches_any_of",
              "value": "4,outro,Outro,atendente,Atendente,humano,Humano"
            }
          ]
        }
      ],
      "properties": {
        "input": "{{widgets.order_issue_q.inbound.Body}}",
        "offset": {
          "x": 0,
          "y": 3400
        }
      }
    },
    {

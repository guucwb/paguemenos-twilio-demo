# ─────────────────────────────────────────────────────────────
# PagueMenos Twilio Demo — Variáveis de Ambiente
# Copie para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=3000

# URL pública do seu backend (sem trailing slash)
# Ex.: https://paguemenos-demo.up.railway.app
BASE_URL=https://SEU_DOMINIO.up.railway.app

# URL pública do WebSocket (wss://)
# Normalmente igual ao BASE_URL mas com wss:// e path /ws/conversationrelay
WS_PUBLIC_URL=wss://SEU_DOMINIO.up.railway.app/ws/conversationrelay

# ── Twilio Core ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twilio Verify ─────────────────────────────────────────────
# Crie em: Console > Verify > Services
VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twilio Flex ───────────────────────────────────────────────
# Workspace SID: Console > TaskRouter > Workspaces
FLEX_WORKSPACE_SID=WSxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Queue SID: Console > TaskRouter > Workspaces > Queues > "Farmacia_Demo"
FLEX_QUEUE_SID=WQxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Workflow SID: Console > TaskRouter > Workspaces > Workflows
FLEX_WORKFLOW_SID=WWxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── WhatsApp / Voice ──────────────────────────────────────────
# Número Twilio com WhatsApp Calling habilitado (E.164)
TWILIO_WHATSAPP_NUMBER=+55119XXXXXXXX

# Para transferência de voz para Flex (número do Flex ou SIP)
# Deixe vazio se usar Enqueue direto no TaskRouter
FLEX_TRANSFER_NUMBER=

# ── Segurança ─────────────────────────────────────────────────
# Token secreto para validar webhooks do Twilio (opcional — use TWILIO_AUTH_TOKEN)
# NODE_ENV controla logs verbosos
NODE_ENV=production
